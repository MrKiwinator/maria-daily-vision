PORT=3001
JWT_SECRET=change-this-to-a-long-random-string-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# Локально: http://localhost:5173 | Продакшен: https://ваш-домен.ru
CORS_ORIGIN=http://localhost:5173
# Продакшен: Express отдаёт собранный фронт из frontend/dist
SERVE_FRONTEND=false
NODE_ENV=development

# Telegram: уведомления при публикации новой новости (POST /api/news)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Публичный URL сайта для ссылки /news/:id (в продакшене — https://ваш-домен.ru)
PUBLIC_SITE_URL=
# База URL для картинки в Telegram (если API на другом домене; иначе как PUBLIC_SITE_URL)
# TELEGRAM_MEDIA_BASE_URL=
# Прокси, если api.telegram.org недоступен с VPS (http://, https://, socks5://)
# TELEGRAM_PROXY_URL=http://127.0.0.1:3128
# NOTIFY_ON_NEWS=false
